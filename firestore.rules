rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Data Model
    // ===============================================================
    // Collection: progamers   (matches client code + admin sitemap)
    // Fields: name, team, game, imageUrl, teamLogoUrl, profileUrl,
    //         gear, settings, source, updatedAt

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "wjsrkdgns123a@gmail.com" && request.auth.token.email_verified == true);
    }

    // IMPORTANT: collection id is `progamers` (no hyphen). An earlier
    // version of this file used `pro-gamers`, which silently matched
    // nothing — all reads/writes fell through to the project default.
    match /progamers/{gamerId} {
      // Anyone can read pro gamer data
      allow read: if true;
      // Only the verified admin email can mutate
      allow write: if isAdmin();
    }

    // ===============================================================
    // Comments: anonymous read/write allowed
    // ===============================================================
    match /comments/{proId}/messages/{commentId} {
      // Anyone can read comments
      allow read: if true;
      // Anyone can create a comment (anonymous)
      allow create: if true;
      // Author can update their own comment, admin can update any
      allow update: if true;
      // Anyone can delete their own (by token), admin can delete any
      allow delete: if true;
    }

    // ===============================================================
    // Settings: read for all, write for admin only
    // ===============================================================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
