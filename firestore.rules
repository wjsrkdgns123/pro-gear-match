rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: pro-gamers
    // Fields: name, team, game, imageUrl, teamLogoUrl, profileUrl, gear, settings, source, updatedAt
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "wjsrkdgns123a@gmail.com" && request.auth.token.email_verified == true);
    }

    match /pro-gamers/{gamerId} {
      // Anyone can read pro gamer data
      allow read: if true;
      // Only admins can write pro gamer data
      allow write: if isAdmin();
    }
  }
}
