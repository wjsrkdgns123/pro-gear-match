rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Data Model
    // ===============================================================
    // Collection: pro-gamers  (with hyphen — matches src/services/aiService.ts,
    // which is the main read path. ProDetail.tsx reads `progamers` without
    // a hyphen; that's a separate bug in that view, not a data move.)
    // Fields: name, team, game, imageUrl, teamLogoUrl, profileUrl,
    //         gear, settings, source, updatedAt

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "wjsrkdgns123a@gmail.com" && request.auth.token.email_verified == true);
    }

    // Collection id is `pro-gamers` — app code (aiService.ts) queries
    // this exact string. Do NOT "fix" the hyphen without first migrating
    // all 500+ existing docs; an earlier attempt broke prod reads.
    match /pro-gamers/{gamerId} {
      // Anyone can read pro gamer data
      allow read: if true;
      // Only the verified admin email can mutate
      allow write: if isAdmin();
    }

    // ===============================================================
    // Comments: anonymous read/write allowed
    // ===============================================================
    match /comments/{proId}/messages/{commentId} {
      // Anyone can read comments
      allow read: if true;
      // Anyone can create a comment (anonymous)
      allow create: if true;
      // Author can update their own comment, admin can update any
      allow update: if true;
      // Anyone can delete their own (by token), admin can delete any
      allow delete: if true;
    }

    // ===============================================================
    // Settings: read for all, write for admin only
    // ===============================================================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
