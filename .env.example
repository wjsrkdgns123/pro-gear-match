# ── AI API keys ─────────────────────────────────────────────────────
# Claude (Anthropic) — REQUIRED. Powers all AI features (pro scraping,
# gear suggestions, YouTube highlights). Claude-only; Gemini is removed.
ANTHROPIC_API_KEY=

# Gemini is no longer used but is still read by vite.config.ts for
# backwards compatibility with legacy deployments. Leave blank.
GEMINI_API_KEY=

# ── App config ──────────────────────────────────────────────────────
# Public base URL (used for canonical links, sitemap.xml, OAuth callback).
APP_URL="http://localhost:3010"

# Cookie-session signing key. ALWAYS override in production.
SESSION_SECRET=

# ── Microsoft OAuth (optional — Excel import feature) ───────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Firebase admin (optional) ───────────────────────────────────────
# If service-account.json is absent on the server, you can paste the
# JSON string here to enable dynamic sitemap + admin-only endpoints.
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# ── Server ──────────────────────────────────────────────────────────
PORT=3010
NODE_ENV=development

# ── Observability (optional — both empty = fully disabled) ──────────
# Sentry DSN for client-side error tracking. Without a DSN, Sentry is a no-op.
VITE_SENTRY_DSN=

# GA4 Measurement ID (G-XXXXXXX). Only loads after the user accepts the
# consent banner; leaving this empty keeps analytics fully off.
VITE_GA4_ID=
